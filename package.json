{
  "name": "opds-server",
  "version": "1.0.0",
  "description": "A basic OPDS server powered by Anna's Archive",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development node --watch --watch-path=server.js --watch-path=lib/ server.js",
    "build": "npm run build --prefix client"
  },
  "keywords": [
    "opds",
    "ebooks",
    "catalog",
    "annas-archive"
  ],
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.2",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0"
  }
}